---
import BaseLayout from '../layouts/BaseLayout.astro';
import { certifications, profile } from '../data/profile';
import { es } from '../i18n/es';
import { withBase } from '../scripts/paths';
import CertCard from '../components/CertCard.astro';

const sortedCerts = [...certifications].sort((a, b) => a.order - b.order);
---

<BaseLayout
  title={`Certifications — ${profile.name}`}
  description={`Certifications and credentials earned by ${profile.name}.`}
>
  <article class="certs-page section">
    <div class="container certs-page-inner">
      <a href={withBase('#certifications')} class="back-link" data-nav-link data-es={es.ui.certificationsBack}>← Back</a>

      <h1 class="certs-title" data-es={es.ui.certificationsLabel}>Certifications<span class="dot">.</span></h1>
      <p class="certs-lead" data-es={es.ui.certificationsLead}>
        All my certifications and training. Click any one to view the credential.
      </p>

      <ul class="certs-list">
        {sortedCerts.map((c) => <CertCard cert={c} />)}
      </ul>
    </div>
  </article>
</BaseLayout>

<style>
  .certs-page {
    padding-top: calc(64px + var(--space-8));
  }
  .certs-page-inner {
    max-width: 960px;
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    transition: color 200ms ease;
  }
  .back-link:hover {
    color: var(--color-accent);
  }
  .certs-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: var(--space-4) 0 var(--space-2);
  }
  .certs-title .dot {
    color: var(--color-accent);
  }
  .certs-lead {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }
  .certs-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    grid-auto-rows: 1fr; /* every row the same height → all cards match */
    gap: var(--space-2);
  }
</style>
