---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, profile } from '../../data/profile';
import type { Project } from '../../data/profile';

export async function getStaticPaths() {
  const sorted = [...projects].sort((a, b) => a.order - b.order);
  return sorted.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      project: p,
      next: sorted[(i + 1) % sorted.length],
    },
  }));
}

interface Props {
  project: Project;
  next: Project;
}

const { project, next } = Astro.props;
const links = [
  { label: 'View on GitHub', url: project.github },
  { label: 'Live demo', url: project.demo },
].filter((l) => l.url);
---

<BaseLayout
  title={`${project.title} — ${profile.name}`}
  description={project.description}
>
  <article class="project-detail section">
    <div class="container detail-inner">
      <a href="/#projects" class="back-link" data-nav-link>← Back to work</a>

      <span class="detail-year">{project.year}</span>
      <h1 class="detail-title">{project.title}</h1>

      {project.metrics && <span class="detail-metric">{project.metrics}</span>}

      <ul class="detail-tags">
        {project.stack.map((t) => <li class="tag-chip">{t}</li>)}
      </ul>

      <div class="detail-visual" transition:name={`project-img-${project.slug}`}>
        <span class="detail-visual-mark">{project.title.split(' ')[0]}</span>
      </div>

      <p class="detail-body">{project.body || project.description}</p>

      {links.length > 0 && (
        <div class="detail-links">
          {links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              {l.label} ↗
            </a>
          ))}
        </div>
      )}

      <a href={`/projects/${next.slug}`} class="next-project">
        <span class="next-label">Next project</span>
        <span class="next-title">{next.title} →</span>
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding-top: calc(64px + var(--space-8));
  }
  .detail-inner {
    max-width: 820px;
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    transition: color 200ms ease;
  }
  .back-link:hover {
    color: var(--color-accent);
  }
  .detail-year {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-4);
  }
  .detail-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: var(--space-1) 0 var(--space-3);
  }
  .detail-metric {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    background: var(--color-accent-2);
    color: #05231d;
    margin-bottom: var(--space-3);
  }
  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin-bottom: var(--space-4);
  }
  .detail-visual {
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 30% 30%, rgba(124, 111, 247, 0.2), transparent 60%),
      radial-gradient(circle at 75% 70%, rgba(0, 212, 170, 0.14), transparent 55%),
      var(--color-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-6);
  }
  .detail-visual-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 6vw, 4rem);
    color: rgba(240, 240, 250, 0.14);
    text-transform: uppercase;
  }
  .detail-body {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: 68ch;
  }
  .detail-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }
  .next-project {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .next-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .next-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h3);
    color: var(--color-text-primary);
    transition: color 200ms ease;
  }
  .next-project:hover .next-title {
    color: var(--color-accent);
  }
</style>
