---
import { stack } from '../data/profile';
import { es } from '../i18n/es';
const categories = Object.entries(stack);
---

<section id="stack" class="section">
  <div class="container">
    <h2 class="section-heading reveal"><span data-es={es.ui.stackHeading}>Stack &amp; Tools</span><span class="dot">.</span></h2>

    <div class="stack-grid">
      {categories.map(([category, items]) => (
        <div class="stack-category">
          <span class="stack-label reveal" data-es={es.stackCategories[category] ?? category}>{category}</span>
          <ul class="stack-pills">
            {items.map((item) => (
              <li class="stack-pill">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .stack-category {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-3);
    align-items: start;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .stack-category:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    padding-top: 6px;
  }
  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
  }

  @media (max-width: 640px) {
    .stack-category {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
