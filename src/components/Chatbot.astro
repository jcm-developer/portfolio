---
import { profile, projects, experience, stack } from '../data/profile';

const chatbotContext = `
You are a conversational AI assistant embedded in the personal portfolio of ${profile.name}, an ${profile.role} based in ${profile.location}.

Your job is to answer questions from recruiters, clients, and collaborators about ${profile.name}. Be helpful, concise, and professional. Speak about ${profile.name} in third person unless asked a direct question as if you were them.

--- PROFILE ---
Name: ${profile.name}
Role: ${profile.role}
Location: ${profile.location}
Email: ${profile.email}
Availability: ${profile.availability}
Languages: ${profile.languages.join(', ')}

Bio:
${profile.bio.p1}
${profile.bio.p2}
${profile.bio.p3}

--- PROJECTS ---
${projects
  .map(
    (p) => `
• ${p.title}: ${p.description}
  Stack: ${p.stack.join(', ')}
  ${p.metrics ? `Impact: ${p.metrics}` : ''}
  ${p.github ? `GitHub: ${p.github}` : ''}
`
  )
  .join('\n')}

--- EXPERIENCE ---
${experience
  .map(
    (e) => `
• ${e.role} at ${e.company} (${e.startDate} – ${e.endDate || 'Present'})
  ${e.description}
  ${e.impact ? `Impact: ${e.impact}` : ''}
  Stack: ${e.stack.join(', ')}
`
  )
  .join('\n')}

--- TECH STACK ---
${Object.entries(stack)
  .map(([cat, items]) => `${cat}: ${items.join(', ')}`)
  .join('\n')}

--- RULES ---
- Never invent data not present above.
- If asked for the email, provide it.
- If asked about salary expectations or confidential info, politely decline.
- Keep answers under 3 short paragraphs unless asked to elaborate.
- If asked something unrelated to ${profile.name}, redirect politely.
- You can suggest they check specific sections of the portfolio for more detail.
`.trim();
---

<div id="chatbot-context" hidden>{chatbotContext}</div>

<div class="chatbot" data-chatbot>
  <!-- Chat window -->
  <div id="chat-window" class="chat-window" role="dialog" aria-label="Ask about Jaume" aria-hidden="true">
    <header class="chat-header">
      <span class="chat-avatar" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 8V4H8" /><rect width="16" height="12" x="4" y="8" rx="2" /><path d="M2 14h2" /><path d="M20 14h2" /><path d="M15 13v2" /><path d="M9 13v2" />
        </svg>
      </span>
      <div class="chat-header-text">
        <strong>Ask me anything</strong>
        <span>about {profile.name}</span>
      </div>
      <button id="chat-close" class="chat-close" aria-label="Close chat">&times;</button>
    </header>

    <div id="chat-messages" class="chat-messages">
      <div class="msg msg-bot">
        Hi! I'm {profile.name.split(' ')[0]}'s assistant. Ask me about his projects,
        experience, or stack — or whether he's available for work.
      </div>
    </div>

    <form id="chat-form" class="chat-input-row" autocomplete="off">
      <input
        id="chat-input"
        class="chat-input"
        type="text"
        placeholder="Type a question…"
        aria-label="Type a question"
        maxlength="500"
      />
      <button type="submit" class="chat-send" aria-label="Send message">→</button>
    </form>
  </div>

  <!-- FAB -->
  <button id="chat-fab" class="chat-fab" aria-label="Open chat">
    <span class="fab-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
      </svg>
    </span>
    <span class="fab-label">Ask me anything</span>
  </button>
</div>

<style>
  .chatbot {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 300;
  }

  .chat-fab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    padding: 12px 18px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.875rem;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(124, 111, 247, 0.4);
    transition: transform 150ms ease, opacity 200ms ease;
  }
  .chat-fab:hover {
    transform: translateY(-2px);
  }
  .fab-icon {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  .chat-window {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 340px;
    max-width: calc(100vw - 32px);
    height: 480px;
    max-height: calc(100vh - 120px);
    display: none;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-2);
  }
  .chat-avatar {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    color: var(--color-accent);
  }
  .chat-header-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .chat-header-text strong {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
  }
  .chat-header-text span {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }
  .chat-close {
    margin-left: auto;
    background: transparent;
    border: none;
    color: var(--color-text-secondary);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }
  .chat-close:hover {
    color: var(--color-text-primary);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.875rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .msg-user {
    align-self: flex-end;
    background: var(--color-accent);
    color: #fff;
    border-bottom-right-radius: 4px;
  }
  .msg-bot {
    align-self: flex-start;
    background: var(--color-surface-2);
    color: var(--color-text-primary);
    border-bottom-left-radius: 4px;
  }
  .msg-error {
    align-self: flex-start;
    background: rgba(124, 111, 247, 0.08);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
  }

  .typing {
    align-self: flex-start;
    display: inline-flex;
    gap: 4px;
    padding: 12px 14px;
    background: var(--color-surface-2);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
  }
  .typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-secondary);
    animation: bounce 1.2s infinite ease-in-out;
  }
  .typing span:nth-child(2) { animation-delay: 0.15s; }
  .typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  .chat-input-row {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid var(--color-border);
  }
  .chat-input {
    flex: 1;
    background: var(--color-surface-2);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 200ms ease;
  }
  .chat-input:focus {
    border-color: var(--color-accent);
  }
  .chat-input::placeholder {
    color: var(--color-text-muted);
  }
  .chat-send {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    width: 42px;
    font-size: 1.1rem;
    cursor: pointer;
    transition: opacity 200ms ease;
  }
  .chat-send:hover {
    opacity: 0.85;
  }
  .chat-send:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media (max-width: 480px) {
    .fab-label {
      display: none;
    }
    .chat-fab {
      padding: 14px;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const API_KEY = import.meta.env.PUBLIC_OPENAI_API_KEY as string | undefined;

  type ChatMessage = { role: 'user' | 'assistant'; content: string };

  function initChatbot() {
    const root = document.querySelector('[data-chatbot]');
    if (!root || root.getAttribute('data-init') === 'true') return;
    root.setAttribute('data-init', 'true');

    const fab = document.getElementById('chat-fab');
    const windowEl = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const form = document.getElementById('chat-form') as HTMLFormElement | null;
    const input = document.getElementById('chat-input') as HTMLInputElement | null;
    const messagesEl = document.getElementById('chat-messages');
    const sendBtn = form?.querySelector('.chat-send') as HTMLButtonElement | null;
    const context = document.getElementById('chatbot-context')?.textContent ?? '';

    if (!fab || !windowEl || !form || !input || !messagesEl) return;

    const history: ChatMessage[] = [];
    let open = false;
    let busy = false;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function scrollToBottom() {
      messagesEl!.scrollTop = messagesEl!.scrollHeight;
    }

    function appendMessage(kind: 'user' | 'bot' | 'error', text: string) {
      const div = document.createElement('div');
      div.className = `msg msg-${kind}`;
      div.textContent = text;
      messagesEl!.appendChild(div);
      scrollToBottom();
    }

    function showTyping() {
      const t = document.createElement('div');
      t.className = 'typing';
      t.id = 'typing-indicator';
      t.innerHTML = '<span></span><span></span><span></span>';
      messagesEl!.appendChild(t);
      scrollToBottom();
    }
    function hideTyping() {
      document.getElementById('typing-indicator')?.remove();
    }

    function openChat() {
      open = true;
      windowEl!.style.display = 'flex';
      windowEl!.setAttribute('aria-hidden', 'false');
      fab!.style.opacity = '0';
      fab!.style.pointerEvents = 'none';
      if (!reduced) {
        gsap.fromTo(
          windowEl,
          { opacity: 0, y: 20, scale: 0.95 },
          { opacity: 1, y: 0, scale: 1, duration: 0.3, ease: 'power2.out' }
        );
      }
      setTimeout(() => input!.focus(), 50);
    }

    function closeChat() {
      open = false;
      windowEl!.setAttribute('aria-hidden', 'true');
      const done = () => {
        windowEl!.style.display = 'none';
        fab!.style.opacity = '1';
        fab!.style.pointerEvents = 'auto';
      };
      if (reduced) {
        done();
      } else {
        gsap.to(windowEl, {
          opacity: 0,
          y: 20,
          scale: 0.95,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: done,
        });
      }
    }

    async function sendMessage(userText: string) {
      history.push({ role: 'user', content: userText });
      appendMessage('user', userText);
      busy = true;
      if (sendBtn) sendBtn.disabled = true;
      showTyping();

      if (!API_KEY) {
        hideTyping();
        appendMessage(
          'error',
          'The assistant is not configured yet. Add PUBLIC_OPENAI_API_KEY to your .env file to enable it.'
        );
        busy = false;
        if (sendBtn) sendBtn.disabled = false;
        return;
      }

      try {
        const response = await fetch('https://api.openai.com/v1/chat/completions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${API_KEY}`,
          },
          body: JSON.stringify({
            model: 'gpt-4o-mini',
            messages: [{ role: 'system', content: context }, ...history],
            max_tokens: 400,
            temperature: 0.7,
          }),
        });

        hideTyping();

        if (!response.ok) {
          appendMessage('error', 'Sorry — the assistant hit an error. Please try again in a moment.');
          busy = false;
          if (sendBtn) sendBtn.disabled = false;
          return;
        }

        const data = await response.json();
        const botReply = data.choices?.[0]?.message?.content ?? 'Sorry, something went wrong.';
        history.push({ role: 'assistant', content: botReply });
        appendMessage('bot', botReply);
      } catch (err) {
        hideTyping();
        appendMessage('error', 'Network error — please check your connection and try again.');
      } finally {
        busy = false;
        if (sendBtn) sendBtn.disabled = false;
      }
    }

    fab.addEventListener('click', openChat);
    closeBtn?.addEventListener('click', closeChat);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) closeChat();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || busy) return;
      input.value = '';
      sendMessage(text);
    });
  }

  document.addEventListener('astro:page-load', initChatbot);
</script>
