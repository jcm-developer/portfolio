---
import { profile, projects, experience, certifications, education, stack } from '../data/profile';
import { es } from '../i18n/es';

const chatbotContext = `
You are a conversational AI assistant embedded in the personal portfolio of ${profile.name}, an ${profile.role} based in ${profile.location}.

Your job is to answer questions from recruiters, clients, and collaborators about ${profile.name}. Be helpful, concise, and professional. Speak about ${profile.name} in third person unless asked a direct question as if you were them.

--- PROFILE ---
Name: ${profile.name}
Role: ${profile.role}
Location: ${profile.location}
Email: ${profile.email}
LinkedIn: ${profile.linkedin}
GitHub: ${profile.github}
Availability: ${profile.availability}
Languages: ${profile.languages.join(', ')}

Bio:
${profile.bio.p1}
${profile.bio.p2}
${profile.bio.p3}

--- PROJECTS ---
${projects
  .map(
    (p) => `
• ${p.title}${p.featured ? ' [FEATURED]' : ''}: ${p.description}
  Slug: ${p.slug}
  Stack: ${p.stack.join(', ')}
  ${p.metrics ? `Impact: ${p.metrics}` : ''}
  ${p.github ? `GitHub: ${p.github}` : ''}
`
  )
  .join('\n')}

--- EXPERIENCE ---
${experience
  .map(
    (e) => `
• ${e.role} at ${e.company} (${e.startDate} – ${e.endDate || 'Present'})
  ${e.description}
  ${e.impact ? `Impact: ${e.impact}` : ''}
  Stack: ${e.stack.join(', ')}
`
  )
  .join('\n')}

--- EDUCATION ---
${education.map((e) => `• ${e.field} — ${e.school}${e.year ? ` (${e.year})` : ''}`).join('\n')}

--- CERTIFICATIONS ---
${certifications
  .map((c) => `• ${c.name} — ${c.issuer}${c.year ? ` (${c.year})` : ''} [${c.stack.join(', ')}]`)
  .join('\n')}

--- TECH STACK ---
${Object.entries(stack)
  .map(([cat, items]) => `${cat}: ${items.join(', ')}`)
  .join('\n')}

--- PORTFOLIO WEBSITE ---
This portfolio website was designed and built by ${profile.name} himself from scratch. It uses Astro, TypeScript, GSAP, and a custom AI assistant (this one). If anyone asks who made this site or who built this portfolio, the answer is ${profile.name}.

--- RULES ---
- Never invent data not present above.
- If asked for the email, provide it.
- If asked about salary expectations or confidential info, politely decline.
- Keep answers SHORT and CLEAR: 1–3 sentences, ideally under 50 words. Get straight to the point — no filler or preamble.
- Reply in PLAIN TEXT only. Never use markdown: no asterisks for bold/italic, no "#" headings, no "-"/"*"/"•" bullet points or numbered lists. If you must list a few things, write them in a sentence separated by commas.
- Only elaborate further if the user explicitly asks for more detail.
- Reply in the same language the user writes in.
- If asked something unrelated to ${profile.name}, redirect politely in one sentence.

--- CONTROLLING THE WEBSITE ---
You can navigate the portfolio for the user — this makes it feel like you control the site. ALWAYS answer in text as well; navigation is in addition to your reply, never instead of it.
- When the user asks about a TOPIC in general, call navigateToSection to scroll the page to the matching section. Pick the section by what it contains:
  • about — who he is, his background, bio, languages, where he's from, career path, personality.
  • projects — his projects and selected work in general.
  • experience — his work history: jobs, companies, roles, dates. Also where his tech stack lives, shown as tags on each role.
  • certifications — his certifications and the issuers (e.g. courses, AI/ML credentials).
  • education — his academic background, studies, degrees, schools, formal training (e.g. "what did he study?", "where did he go to school?", "his academic background").
  • contact — how to reach him (email, getting in touch, hiring, availability).
  Always map the question to the closest section — e.g. "what languages does he speak?", "where is he from?" → about. If truly nothing fits, just answer in text.
- When the user asks about ONE SPECIFIC project (e.g. "what's his best/featured project?", "tell me about Scalextric", "the VR one"), call openProject with that project's slug to open its detail page, then describe it in your text reply. The FEATURED projects are the most outstanding ones.
- Match the section/project to the question; if no navigation clearly fits, just answer in text without calling a tool.
- Never mention slugs, function names, or that you are "calling a tool" — just talk naturally.
`.trim();

// Navigation metadata consumed by the client to build the OpenAI tool schema.
const navMeta = {
  sections: ['about', 'projects', 'experience', 'certifications', 'education', 'contact'],
  projects: projects.map((p) => p.slug),
};
---

<div id="chatbot-context" hidden>{chatbotContext}</div>
<script type="application/json" id="chatbot-nav" is:inline set:html={JSON.stringify(navMeta)}></script>

<div class="chatbot" data-chatbot data-open="false" transition:persist="chatbot">
  <div id="agent-nav-overlay" aria-hidden="true"></div>
  <aside id="chat-window" class="chat-panel" role="dialog" aria-modal="false" aria-label="Ask about Jaume" aria-hidden="true">

    <header class="chat-header">
      <div class="chat-avatar-wrap" aria-hidden="true">
        <span class="chat-avatar">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8" /><rect width="16" height="12" x="4" y="8" rx="2" /><path d="M2 14h2" /><path d="M20 14h2" /><path d="M15 13v2" /><path d="M9 13v2" />
          </svg>
        </span>
        <span class="chat-online-dot" aria-hidden="true"></span>
      </div>
      <div class="chat-header-text">
        <strong data-es={es.ui.chatbot.title}>Ask me anything</strong>
        <span data-es={es.ui.chatbot.about}>about {profile.name}</span>
      </div>
      <button id="chat-close" class="chat-close" aria-label="Close chat">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
    </header>

    <div id="chat-messages" class="chat-messages" data-lenis-prevent>
      <div class="msg msg-bot" data-es={es.ui.chatbot.greeting}>{`Hi! I'm ${profile.name.split(' ')[0]}'s assistant. Ask me about his projects, experience, or stack — or whether he's available for work.`}</div>
    </div>

    <div id="chat-suggestions" class="chat-suggestions" aria-label="Suggested questions">
      <button class="suggestion-chip" type="button">What's his tech stack?</button>
      <button class="suggestion-chip" type="button">Is he available?</button>
      <button class="suggestion-chip" type="button">Show me his projects</button>
      <button class="suggestion-chip" type="button">How to contact him?</button>
    </div>

    <form id="chat-form" class="chat-input-row" autocomplete="off">
      <input
        id="chat-input"
        class="chat-input"
        type="text"
        placeholder="Type a question…"
        data-es-placeholder={es.ui.chatbot.placeholder}
        aria-label="Type a question"
        maxlength="500"
      />
      <button type="submit" class="chat-send" aria-label="Send message">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m22 2-7 20-4-9-9-4 20-7z" />
        </svg>
      </button>
    </form>
  </aside>
</div>

<style>
  .chat-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    height: 100dvh;
    width: var(--chat-w);
    max-width: 100vw;
    z-index: 250;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-left: none;
    /* Inset violet glow on the left edge instead of a flat border */
    box-shadow:
      inset 1px 0 0 0 var(--color-border),
      inset 2px 0 0 0 rgba(124, 111, 247, 0.15),
      -24px 0 64px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    transform: translateX(100%);
    visibility: hidden;
    will-change: transform;
    transition:
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 420ms;
  }
  :global(body.chat-open) .chat-panel {
    transform: translateX(0);
    visibility: visible;
    /* Intensify the accent glow when open */
    box-shadow:
      inset 1px 0 0 0 rgba(124, 111, 247, 0.4),
      inset 2px 0 0 0 rgba(124, 111, 247, 0.12),
      -24px 0 64px rgba(0, 0, 0, 0.4);
    transition:
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 420ms ease,
      visibility 0s;
  }
  :global(html[data-theme='light']) .chat-panel {
    box-shadow:
      inset 1px 0 0 0 var(--color-border),
      inset 2px 0 0 0 rgba(91, 79, 214, 0.1),
      -24px 0 64px rgba(20, 20, 50, 0.18);
  }
  :global(html[data-theme='light']) :global(body.chat-open) .chat-panel {
    box-shadow:
      inset 1px 0 0 0 rgba(91, 79, 214, 0.35),
      inset 2px 0 0 0 rgba(91, 79, 214, 0.08),
      -24px 0 64px rgba(20, 20, 50, 0.18);
  }

  /* ── Agent navigation glow overlay ─────────────────────────────────── */
  #agent-nav-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 200;
    opacity: 0;
    border-radius: 0;
    box-shadow: inset 0 0 0 0 rgba(124, 111, 247, 0);
    filter: blur(0px);
  }
  :global(body.chat-open) #agent-nav-overlay {
    right: var(--chat-w);
  }
  #agent-nav-overlay.is-navigating {
    animation: nav-border-pulse 1.8s ease-out forwards;
  }
  @keyframes nav-border-pulse {
    0%   { opacity: 0;   box-shadow: inset 0 0 30px 8px  rgba(124, 111, 247, 0.0); filter: blur(4px); }
    15%  { opacity: 1;   box-shadow: inset 0 0 70px 25px rgba(124, 111, 247, 0.55); filter: blur(8px); }
    45%  { opacity: 0.9; box-shadow: inset 0 0 90px 35px rgba(124, 111, 247, 0.45); filter: blur(10px); }
    100% { opacity: 0;   box-shadow: inset 0 0 50px 15px rgba(124, 111, 247, 0.0); filter: blur(6px); }
  }

  /* ── Header ─────────────────────────────────────────────────────────── */
  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
    /* Glass treatment matching the nav dock */
    background: rgba(17, 17, 24, 0.7);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    flex: none;
  }
  :global(html[data-theme='light']) .chat-header {
    background: rgba(255, 255, 255, 0.72);
  }

  /* Avatar — rounded square with accent glow, matching dock item aesthetic */
  .chat-avatar-wrap {
    position: relative;
    flex: none;
  }
  .chat-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--color-accent-glow);
    border: 1px solid rgba(124, 111, 247, 0.35);
    color: var(--color-accent);
    box-shadow: 0 0 14px var(--color-accent-glow);
    flex: none;
  }

  /* Teal online dot — mirrors the availability badge in Contact section */
  .chat-online-dot {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent-2);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 6px rgba(0, 212, 170, 0.6);
    animation: pulse-dot 2.2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 6px rgba(0, 212, 170, 0.6); }
    50%       { box-shadow: 0 0 10px rgba(0, 212, 170, 0.9); }
  }
  :global(html[data-theme='light']) .chat-online-dot {
    border-color: #fff;
  }

  .chat-header-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .chat-header-text strong {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .chat-header-text span {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chat-close {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex: none;
    border-radius: 8px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease;
  }
  .chat-close:hover {
    background: var(--color-surface-2);
    border-color: var(--color-border);
    color: var(--color-text-primary);
  }

  /* ── Messages ─────────────────────────────────────────────────────────── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--color-bg);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .chat-messages::-webkit-scrollbar {
    display: none;
  }

  /* Shared message shell — globally scoped for runtime-created nodes */
  :global(.msg) {
    max-width: 86%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 0.875rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-wrap: break-word;
    animation: msg-in 200ms ease both;
  }
  @keyframes msg-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  :global(.msg-user) {
    align-self: flex-end;
    background: var(--color-accent);
    color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 2px 12px rgba(124, 111, 247, 0.25);
  }
  /* Bot messages match the project card treatment */
  :global(.msg-bot) {
    align-self: flex-start;
    background: var(--color-gradient-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    border-bottom-left-radius: 4px;
  }
  :global(.msg-error) {
    align-self: flex-start;
    background: rgba(124, 111, 247, 0.07);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    border-bottom-left-radius: 4px;
  }

  /* Action pill — left-aligned in the thread, signals navigation */
  :global(.msg-action) {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    background: var(--color-accent-glow);
    border: 1px solid rgba(124, 111, 247, 0.25);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    max-width: 100%;
    animation: action-in 220ms ease both;
  }
  :global(.msg-action svg) {
    flex: none;
    opacity: 0.85;
  }
  @keyframes action-in {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* Typing indicator — matches bot message card style */
  :global(.typing) {
    align-self: flex-start;
    display: inline-flex;
    gap: 5px;
    padding: 13px 16px;
    background: var(--color-gradient-card);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    animation: msg-in 200ms ease both;
  }
  :global(.typing span) {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
    animation: bounce 1.2s infinite ease-in-out;
  }
  :global(.typing span:nth-child(2)) { animation-delay: 0.15s; }
  :global(.typing span:nth-child(3)) { animation-delay: 0.3s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* ── Suggestion chips ─────────────────────────────────────────────────── */
  /* Pill-style quick-question chips — match stack-pill from global.css */
  .chat-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 14px 14px;
    background: var(--color-bg);
  }
  .chat-suggestions.hidden {
    display: none;
  }
  .suggestion-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 200ms ease, color 200ms ease, background 200ms ease, transform 150ms ease;
    will-change: transform;
  }
  .suggestion-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-glow);
    transform: translateY(-1px);
  }

  /* ── Input row ────────────────────────────────────────────────────────── */
  .chat-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-2);
    flex: none;
  }
  .chat-input {
    flex: 1;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 10px 13px;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .chat-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }
  .chat-input::placeholder {
    color: var(--color-text-muted);
  }

  /* Send button — matches .btn-primary from global.css */
  .chat-send {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex: none;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: opacity 200ms ease, transform 150ms ease;
    will-change: transform;
  }
  .chat-send:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .chat-send:active {
    transform: translateY(0);
  }
  .chat-send:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .chat-panel {
      width: 100%;
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-panel {
      transition: visibility 0s !important;
    }
    :global(.msg),
    :global(.typing) {
      animation: none !important;
    }
    .chat-online-dot {
      animation: none !important;
    }
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';
  import { withBase, isHome } from '../scripts/paths';

  const API_KEY = import.meta.env.PUBLIC_OPENAI_API_KEY as string | undefined;

  type ChatMessage = {
    role: 'user' | 'assistant' | 'tool';
    content: string | null;
    tool_calls?: any[];
    tool_call_id?: string;
  };

  type NavMeta = { sections: string[]; projects: string[] };

  function initChatbot() {
    const root = document.querySelector('[data-chatbot]');
    if (!root || root.getAttribute('data-init') === 'true') return;
    root.setAttribute('data-init', 'true');

    const windowEl = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const form = document.getElementById('chat-form') as HTMLFormElement | null;
    const input = document.getElementById('chat-input') as HTMLInputElement | null;
    const messagesEl = document.getElementById('chat-messages');
    const suggestionsEl = document.getElementById('chat-suggestions');
    const sendBtn = form?.querySelector('.chat-send') as HTMLButtonElement | null;
    const context = document.getElementById('chatbot-context')?.textContent ?? '';

    if (!windowEl || !form || !input || !messagesEl) return;

    let navMeta: NavMeta = { sections: [], projects: [] };
    try {
      navMeta = JSON.parse(document.getElementById('chatbot-nav')?.textContent ?? '{}');
    } catch {
      /* fall back to empty */
    }

    const tools: any[] = [];
    if (navMeta.sections?.length) {
      tools.push({
        type: 'function',
        function: {
          name: 'navigateToSection',
          description:
            'Scroll the portfolio to a section when the user asks about that topic in general. Call this IN ADDITION to answering in text.',
          parameters: {
            type: 'object',
            properties: {
              section: { type: 'string', enum: navMeta.sections },
            },
            required: ['section'],
          },
        },
      });
    }
    if (navMeta.projects?.length) {
      tools.push({
        type: 'function',
        function: {
          name: 'openProject',
          description:
            'Open the detail page of one specific project when the user asks about it specifically. Call this IN ADDITION to answering in text.',
          parameters: {
            type: 'object',
            properties: {
              slug: { type: 'string', enum: navMeta.projects },
            },
            required: ['slug'],
          },
        },
      });
    }

    const history: ChatMessage[] = [];
    let open = false;
    let busy = false;

    // ── Page control ──────────────────────────────────────────────────────
    function scrollToSection(section: string) {
      const target = document.getElementById(section);
      const lenis = (window as any).__lenis;
      if (target) {
        if (lenis && typeof lenis.scrollTo === 'function') lenis.scrollTo(target, { offset: -88 });
        else target.scrollIntoView({ behavior: 'smooth' });
        return;
      }
      navigate(withBase(`#${section}`));
    }

    function goToSection(section: string) {
      if (isHome()) scrollToSection(section);
      else navigate(withBase(`#${section}`));
    }

    function openProject(slug: string) {
      navigate(withBase(`projects/${slug}`));
    }

    const SECTION_LABELS: Record<string, string> = {
      about: 'About',
      projects: 'Projects',
      experience: 'Experience',
      certifications: 'Certifications',
      contact: 'Contact',
    };

    function runAction(name: string, args: Record<string, any>): string {
      if (name === 'navigateToSection' && args.section) {
        goToSection(args.section);
        const label = SECTION_LABELS[args.section] ?? args.section;
        triggerNavGlow();
        appendMessage('action', `Navigating to ${label}`);
        return `Scrolled to the ${args.section} section.`;
      }
      if (name === 'openProject' && args.slug) {
        openProject(args.slug);
        const label = args.slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
        triggerNavGlow();
        appendMessage('action', `Opening project — ${label}`);
        return `Opened the ${args.slug} project page.`;
      }
      return 'No action taken.';
    }

    function scrollToBottom() {
      messagesEl!.scrollTop = messagesEl!.scrollHeight;
    }

    function stripMarkdown(text: string): string {
      return text
        .replace(/```[\s\S]*?```/g, (m) => m.replace(/```/g, '').trim())
        .replace(/`([^`]+)`/g, '$1')
        .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
        .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
        .replace(/(\*\*|__)(.*?)\1/g, '$2')
        .replace(/(\*|_)(.*?)\1/g, '$2')
        .replace(/~~(.*?)~~/g, '$1')
        .replace(/^\s{0,3}#{1,6}\s+/gm, '')
        .replace(/^\s{0,3}>\s?/gm, '')
        .replace(/^\s*[-*+]\s+/gm, '')
        .replace(/^\s*\d+\.\s+/gm, '')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
    }

    const ACTION_ICON = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>`;

    function triggerNavGlow() {
      const overlay = document.getElementById('agent-nav-overlay');
      if (!overlay) return;
      overlay.classList.remove('is-navigating');
      void (overlay as HTMLElement).offsetWidth;
      overlay.classList.add('is-navigating');
      setTimeout(() => overlay.classList.remove('is-navigating'), 1800);
    }

    function appendMessage(kind: 'user' | 'bot' | 'error' | 'action', text: string) {
      const div = document.createElement('div');
      div.className = `msg msg-${kind}`;
      if (kind === 'action') {
        div.innerHTML = ACTION_ICON + text;
      } else {
        div.textContent = kind === 'bot' ? stripMarkdown(text) : text;
      }
      messagesEl!.appendChild(div);
      scrollToBottom();
    }

    function showTyping() {
      const t = document.createElement('div');
      t.className = 'typing';
      t.id = 'typing-indicator';
      t.innerHTML = '<span></span><span></span><span></span>';
      messagesEl!.appendChild(t);
      scrollToBottom();
    }
    function hideTyping() {
      document.getElementById('typing-indicator')?.remove();
    }

    // Hide suggestion chips after the first interaction
    function hideSuggestions() {
      suggestionsEl?.classList.add('hidden');
    }

    function syncToggles(isOpen: boolean) {
      document.querySelectorAll('[data-chat-toggle]').forEach((btn) => {
        btn.setAttribute('aria-expanded', String(isOpen));
        btn.setAttribute('aria-label', isOpen ? 'Cerrar chat' : 'Abrir chat');
      });
    }

    function refreshLayout() {
      setTimeout(() => {
        window.dispatchEvent(new Event('resize'));
        (window as any).__lenis?.resize?.();
      }, 440);
    }

    function openChat() {
      if (open) return;
      open = true;
      root!.setAttribute('data-open', 'true');
      document.body.classList.add('chat-open');
      windowEl!.setAttribute('aria-hidden', 'false');
      syncToggles(true);
      refreshLayout();
      setTimeout(() => input!.focus(), 440);
    }

    function closeChat() {
      if (!open) return;
      open = false;
      root!.setAttribute('data-open', 'false');
      document.body.classList.remove('chat-open');
      windowEl!.setAttribute('aria-hidden', 'true');
      syncToggles(false);
      refreshLayout();
    }

    function toggleChat() {
      open ? closeChat() : openChat();
    }

    async function requestCompletion(): Promise<ChatMessage | null> {
      const response = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${API_KEY}`,
        },
        body: JSON.stringify({
          model: 'gpt-4o-mini',
          messages: [{ role: 'system', content: context }, ...history],
          ...(tools.length ? { tools, tool_choice: 'auto' } : {}),
          max_tokens: 180,
          temperature: 0.6,
        }),
      });
      if (!response.ok) return null;
      const data = await response.json();
      return data.choices?.[0]?.message ?? null;
    }

    async function sendMessage(userText: string) {
      hideSuggestions();
      history.push({ role: 'user', content: userText });
      appendMessage('user', userText);
      busy = true;
      if (sendBtn) sendBtn.disabled = true;
      showTyping();

      if (!API_KEY) {
        hideTyping();
        appendMessage(
          'error',
          'The assistant is not configured yet. Add PUBLIC_OPENAI_API_KEY to your .env file to enable it.'
        );
        busy = false;
        if (sendBtn) sendBtn.disabled = false;
        return;
      }

      try {
        let spoke = false;
        for (let turn = 0; turn < 3; turn++) {
          const msg = await requestCompletion();
          if (!msg) {
            hideTyping();
            appendMessage('error', 'Sorry — the assistant hit an error. Please try again in a moment.');
            return;
          }

          history.push({
            role: 'assistant',
            content: msg.content ?? null,
            ...(msg.tool_calls ? { tool_calls: msg.tool_calls } : {}),
          });

          if (msg.content) {
            hideTyping();
            appendMessage('bot', msg.content);
            spoke = true;
          }

          const calls = msg.tool_calls ?? [];
          if (!calls.length) break;

          for (const call of calls) {
            let parsed: Record<string, any> = {};
            try {
              parsed = JSON.parse(call.function?.arguments ?? '{}');
            } catch {
              /* malformed args — runAction will no-op */
            }
            const result = runAction(call.function?.name ?? '', parsed);
            history.push({ role: 'tool', tool_call_id: call.id, content: result });
          }

          if (spoke) break;
        }

        if (!spoke) {
          hideTyping();
          appendMessage('bot', 'Done — take a look.');
        }
      } catch (err) {
        hideTyping();
        appendMessage('error', 'Network error — please check your connection and try again.');
      } finally {
        hideTyping();
        busy = false;
        if (sendBtn) sendBtn.disabled = false;
      }
    }

    // Suggestion chip click handlers
    suggestionsEl?.querySelectorAll('.suggestion-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const text = chip.textContent?.trim() ?? '';
        if (!text || busy) return;
        sendMessage(text);
      });
    });

    closeBtn?.addEventListener('click', closeChat);
    document.addEventListener('chatbot:toggle', toggleChat);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) closeChat();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || busy) return;
      input.value = '';
      sendMessage(text);
    });
  }

  function syncChatState() {
    const root = document.querySelector('[data-chatbot]');
    const isOpen = root?.getAttribute('data-open') === 'true';
    document.body.classList.toggle('chat-open', isOpen);
    document.querySelectorAll('[data-chat-toggle]').forEach((btn) => {
      btn.setAttribute('aria-expanded', String(isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Cerrar chat' : 'Abrir chat');
    });
  }

  document.addEventListener('astro:page-load', () => {
    initChatbot();
    syncChatState();
  });
</script>
