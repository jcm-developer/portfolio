---
import { profile } from '../data/profile';
import { es } from '../i18n/es';

const socials = [
  { label: 'LinkedIn', url: profile.linkedin },
  { label: 'GitHub', url: profile.github },
].filter((s) => s.url);
---

<section id="contact" class="section">
  <div class="container contact-inner">
    <span class="availability reveal">
      <span class="availability-dot"></span><span data-es={es.availability}>{profile.availability}</span>
    </span>

    <h2 class="section-heading reveal"><span data-es={es.ui.contact.heading}>Let's build something</span><span class="dot">.</span></h2>

    <p class="contact-lead reveal" data-es={es.ui.contact.lead}>
      Open to AI/ML and software roles, freelance projects, and collaborations.
      The fastest way to reach me is email.
    </p>

    <div class="contact-cta reveal">
      <a href={`mailto:${profile.email}`} class="btn-primary" data-es={es.ui.contact.sendEmail}>Send an email</a>
    </div>

    <div class="contact-meta reveal">
      <button
        type="button"
        class="contact-line contact-copy"
        data-copy={profile.email}
        data-label-en="Copy email"
        data-label-es={es.ui.contact.copyEmail}
        data-copied-en="Copied!"
        data-copied-es={es.ui.contact.copied}
        aria-label="Copy email address"
      >
        <span class="copy-email">{profile.email}</span>
        <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="13" height="13" x="9" y="9" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </button>
      <a href={`tel:${profile.phone.replace(/\s+/g, '')}`} class="contact-line">{profile.phone}</a>
    </div>

    {socials.length > 0 && (
      <div class="socials reveal">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={s.label}>
            {s.label === 'LinkedIn' ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0z"/>
              </svg>
            ) : (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.12-.31-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.18.77.84 1.23 1.91 1.23 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .contact-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .availability {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent-2);
    border: 1px solid rgba(0, 212, 170, 0.3);
    background: rgba(0, 212, 170, 0.08);
    padding: 6px 14px;
    border-radius: var(--radius-pill);
  }
  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent-2);
    box-shadow: 0 0 8px var(--color-accent-2);
  }

  .contact-lead {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
  }

  .contact-cta {
    margin-top: var(--space-1);
  }

  .contact-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .contact-line {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    transition: color 200ms ease;
  }
  .contact-line:hover {
    color: var(--color-accent);
  }

  /* Email is a copy-to-clipboard button styled to blend with the phone line. */
  .contact-copy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .contact-copy .copy-icon,
  .contact-copy .check-icon {
    opacity: 0;
    transition: opacity 200ms ease, color 200ms ease;
    color: var(--color-text-muted);
  }
  .contact-copy:hover .copy-icon {
    opacity: 0.7;
  }
  .contact-copy.copied .copy-icon {
    opacity: 0 !important;
  }
  .contact-copy.copied {
    color: var(--color-accent-2);
  }
  .contact-copy.copied .check-icon {
    opacity: 1;
    color: var(--color-accent-2);
  }
  /* Stack the two icons so swapping copy → check doesn't shift the text. */
  .contact-copy .check-icon {
    margin-left: -22px;
  }

  .socials {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }
  .social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-copy .copy-icon,
    .contact-copy .check-icon {
      transition: none;
    }
  }
</style>

<script>
  function initCopyEmail() {
    const btn = document.querySelector<HTMLButtonElement>('.contact-copy');
    if (!btn || btn.dataset.init === 'true') return;
    btn.dataset.init = 'true';

    const labelEl = btn.querySelector<HTMLElement>('.copy-email');
    const original = btn.dataset.copy ?? '';
    let resetTimer = 0;

    btn.addEventListener('click', async () => {
      if (!original || !labelEl) return;

      try {
        await navigator.clipboard.writeText(original);
      } catch {
        // Fallback for browsers without the async clipboard API.
        const ta = document.createElement('textarea');
        ta.value = original;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
        } catch {
          /* give up silently */
        }
        ta.remove();
      }

      const isEs = (() => {
        try {
          return localStorage.getItem('lang') === 'es';
        } catch {
          return false;
        }
      })();
      const copiedText = (isEs ? btn.dataset.copiedEs : btn.dataset.copiedEn) ?? 'Copied!';

      btn.classList.add('copied');
      labelEl.textContent = copiedText;

      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        btn.classList.remove('copied');
        labelEl.textContent = original;
      }, 1600);
    });
  }

  document.addEventListener('astro:page-load', initCopyEmail);
</script>
