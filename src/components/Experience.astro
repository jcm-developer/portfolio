---
import { experience, certifications, education } from '../data/profile';
import { es, esDate } from '../i18n/es';
import { withBase } from '../scripts/paths';
import CertCard from './CertCard.astro';
const sorted = [...experience].sort((a, b) => a.order - b.order);
const sortedCerts = [...certifications].sort((a, b) => a.order - b.order);
// On the home page we preview the first few; the full list lives on /certifications.
const CERTS_PREVIEW = 3;
const previewCerts = sortedCerts.slice(0, CERTS_PREVIEW);
const hasMoreCerts = sortedCerts.length > CERTS_PREVIEW;
---

<section id="experience" class="section">
  <div class="container">
    <h2 class="section-heading reveal"><span data-es={es.ui.experienceHeading}>Experience</span><span class="dot">.</span></h2>

    <div class="timeline">
      {sorted.map((job) => (
        <article class="timeline-entry">
          <span class:list={['timeline-dot', { current: job.current }]}></span>
          <div class="entry-body">
            <span class="entry-dates" data-es={esDate(`${job.startDate} – ${job.endDate}`)}>{job.startDate} – {job.endDate}</span>
            <h3 class="entry-title">
              {job.company} <span class="entry-role">— <span data-es={es.experience[job.company]?.role ?? job.role}>{job.role}</span></span>
            </h3>
            <p class="entry-desc" data-es={es.experience[job.company]?.description ?? job.description}>{job.description}</p>
            {job.impact && <p class="entry-impact">{job.impact}</p>}
            <ul class="entry-tags">
              {job.stack.map((t) => <li class="tag-chip">{t}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="certifications reveal" id="certifications">
      <span class="education-label" data-es={es.ui.certificationsLabel}>Certifications</span>
      <ul class="certs-list">
        {previewCerts.map((c) => <CertCard cert={c} />)}

        {hasMoreCerts && (
          <li class="cert-more">
            <a class="cert-more-link" href={withBase('certifications')} data-nav-link>
              <span class="cert-more-count">{sortedCerts.length}</span>
              <span class="cert-more-text" data-es="Ver todas las certificaciones →">
                View all certifications →
              </span>
            </a>
          </li>
        )}
      </ul>
    </div>

    <div class="education reveal" id="education">
      <span class="education-label" data-es={es.ui.educationLabel}>Education &amp; Learning</span>
      <ul class="education-list">
        {education.map((e) => (
          <li class="education-item">
            <span class="edu-year">{e.year}</span>
            <span class="edu-school">{e.school}</span>
            <span class="edu-field" data-es={es.education[e.school] ?? e.field}>{e.field}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    margin-left: 8px;
    border-left: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-bottom: var(--space-2);
  }

  .timeline-entry {
    position: relative;
    padding-left: var(--space-4);
  }

  .timeline-dot {
    position: absolute;
    left: -6.5px;
    top: 5px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .timeline-dot.current {
    animation: pulse 2.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 0 rgba(124, 111, 247, 0.5); }
    50% { box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 8px rgba(124, 111, 247, 0); }
  }

  .entry-dates {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
  .entry-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h3);
    margin: 4px 0 8px;
    color: var(--color-text-primary);
  }
  .entry-role {
    color: var(--color-text-secondary);
    font-weight: 400;
  }
  .entry-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    max-width: 65ch;
  }
  .entry-impact {
    font-size: 0.9375rem;
    color: var(--color-accent-2);
    margin-top: 4px;
  }
  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin-top: var(--space-2);
  }

  .certifications {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 88px;
  }
  .certs-list {
    list-style: none;
    margin-top: var(--space-3);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    grid-auto-rows: 1fr; /* every row the same height → all cards match */
    gap: var(--space-2);
  }
  /* Prominent "View all" card — an accent-filled tile that stands out from
     the neutral certification cards and links to the full /certifications page. */
  .cert-more {
    list-style: none;
  }
  .cert-more-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 100%;
    min-height: 96px;
    padding: var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    text-align: center;
    transition: border-color 200ms ease, background 200ms ease, color 200ms ease, transform 200ms ease;
  }
  .cert-more-link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    transform: translateY(-2px);
  }
  .cert-more-count {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.75rem;
    line-height: 1;
    color: var(--color-accent);
  }
  .cert-more-text {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .education {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 88px;
  }
  .education-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .education-list {
    list-style: none;
    margin-top: var(--space-3);
    display: grid;
    gap: var(--space-2);
  }
  .education-item {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: var(--space-2);
    align-items: baseline;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }
  .education-item:last-child {
    border-bottom: none;
  }
  .edu-year {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .edu-school {
    color: var(--color-text-primary);
    font-weight: 500;
  }
  .edu-field {
    grid-column: 2;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 640px) {
    .education-item {
      grid-template-columns: 1fr;
    }
    .edu-field {
      grid-column: 1;
    }
  }
</style>
