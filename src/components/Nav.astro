---
import { profile } from '../data/profile';
import { es } from '../i18n/es';
import Logo from './Logo.astro';
import { withBase } from '../scripts/paths';
---

<nav id="main-nav">
  <div class="dock" id="nav-dock">
    <a href={withBase('#top')} class="dock-item dock-logo" data-nav-link aria-label={`${profile.name} — home`}>
      <Logo />
      <span class="dock-tip" data-es="Inicio">Home</span>
    </a>

    <span class="dock-sep" aria-hidden="true"></span>

    <a href={withBase('#about')} class="dock-item" data-nav-link aria-label="About">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />
      </svg>
      <span class="dock-tip" data-es={es.ui.nav.about}>About</span>
    </a>

    <a href={withBase('#projects')} class="dock-item" data-nav-link aria-label="Projects">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" /><rect x="3" y="14" width="7" height="7" rx="1.5" />
      </svg>
      <span class="dock-tip" data-es={es.ui.nav.projects}>Projects</span>
    </a>

    <a href={withBase('#stack')} class="dock-item" data-nav-link aria-label="Stack">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 2 2 7l10 5 10-5-10-5Z" /><path d="m2 17 10 5 10-5" /><path d="m2 12 10 5 10-5" />
      </svg>
      <span class="dock-tip" data-es={es.ui.nav.stack}>Stack</span>
    </a>

    <a href={withBase('#experience')} class="dock-item" data-nav-link aria-label="Experience">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
      </svg>
      <span class="dock-tip" data-es={es.ui.nav.experience}>Experience</span>
    </a>

    <a href={withBase('#contact')} class="dock-item" data-nav-link aria-label="Contact">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 6-10 7L2 6" />
      </svg>
      <span class="dock-tip" data-es={es.ui.nav.contact}>Contact</span>
    </a>

    <span class="dock-sep" aria-hidden="true"></span>

    <button type="button" class="dock-item lang-toggle" aria-label="Cambiar a español">ES</button>

    <button type="button" class="dock-item theme-toggle" aria-label="Activar modo oscuro" aria-pressed="true">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </button>
  </div>
</nav>

<style>
  #main-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 16px;
    pointer-events: none; /* only the dock itself is interactive */
  }

  /* The floating glass dock — a contained pill, not a full-width bar. */
  .dock {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px;
    border-radius: 20px;
    background: rgba(17, 17, 24, 0.55);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 10px 40px -8px rgba(0, 0, 0, 0.55),
      0 2px 8px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
    transition: background 300ms ease, border-color 300ms ease, box-shadow 300ms ease;
  }
  #main-nav.scrolled .dock {
    background: rgba(17, 17, 24, 0.78);
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Dock items — rounded squares that magnify on hover (see script). */
  .dock-item {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex: none;
    border: none;
    border-radius: 13px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    isolation: isolate; /* own stacking context so the chip can sit behind content */
    transform-origin: center center;
    transition: background 200ms ease, color 200ms ease;
    will-change: transform;
  }
  .dock-item svg {
    display: block;
    width: 21px;
    height: 21px;
  }
  .dock-item::before {
    /* subtle filled chip that fades in on hover, behind the icon/label */
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background: var(--color-surface-2);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .dock-item:hover {
    color: var(--color-accent);
  }
  .dock-item:hover::before {
    opacity: 1;
  }

  .dock-logo {
    width: auto;
    padding: 0 12px;
  }

  .lang-toggle {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* Tooltip label BELOW each item — the dock sits at the top of the viewport,
     so labels drop downward (opposite of a bottom-anchored macOS dock). */
  .dock-tip {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    padding: 4px 10px;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    white-space: nowrap;
    color: var(--color-text-primary);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 18px -6px rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease, transform 180ms ease;
    z-index: 2;
  }
  .dock-tip::after {
    /* little pointer triangle, pointing up toward its item */
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-bottom-color: var(--color-surface-2);
  }
  .dock-item:hover .dock-tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .dock-sep {
    width: 1px;
    height: 26px;
    flex: none;
    margin: 0 3px;
    background: var(--color-border);
    transition: background 300ms ease;
  }
  #main-nav.scrolled .dock-sep {
    background: var(--color-border-glow);
  }

  /* Theme icon: show the icon for the mode you'll switch TO. */
  .theme-toggle .icon-sun { display: block; }
  .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-sun { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-moon { display: block; }

  /* Light theme glass tint */
  :global(html[data-theme='light']) .dock {
    background: rgba(255, 255, 255, 0.6);
    border-color: rgba(0, 0, 0, 0.06);
    box-shadow:
      0 10px 40px -8px rgba(20, 20, 50, 0.18),
      0 2px 8px rgba(20, 20, 50, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  :global(html[data-theme='light']) #main-nav.scrolled .dock {
    background: rgba(255, 255, 255, 0.82);
    border-color: rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 600px) {
    #main-nav {
      padding: 10px;
    }
    .dock {
      gap: 2px;
      padding: 6px;
      border-radius: 17px;
    }
    .dock-item {
      width: 40px;
      height: 40px;
      border-radius: 11px;
    }
    .dock-item svg {
      width: 19px;
      height: 19px;
    }
    .dock-logo {
      padding: 0 9px;
    }
    .dock-sep {
      margin: 0 1px;
      height: 22px;
    }
  }

  @media (max-width: 360px) {
    .dock-item {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { syncPreferences, toggleLang, toggleTheme } from '../scripts/i18n';
  import { isHome } from '../scripts/paths';

  // Apply stored language + theme to the freshly-parsed DOM as early as possible.
  syncPreferences();

  function smoothScrollTo(hash: string) {
    const id = hash.replace(/^.*#/, '');
    const target = id ? document.getElementById(id) : null;
    const lenis = (window as any).__lenis;
    if (target) {
      if (lenis && typeof lenis.scrollTo === 'function') {
        lenis.scrollTo(target, { offset: -88 });
      } else {
        target.scrollIntoView({ behavior: 'smooth' });
      }
      return true;
    }
    return false;
  }

  // --- macOS-style dock magnification ------------------------------------
  // On pointer move we scale each item by its horizontal distance to the
  // cursor, so the dock "bulges" around the hovered icon. Touch + reduced
  // motion users get a plain dock. Re-bound on every View Transition because
  // the nav DOM is swapped on navigation.
  let cleanupDock: (() => void) | null = null;

  function initDock() {
    cleanupDock?.();
    cleanupDock = null;

    const finePointer = window.matchMedia('(pointer: fine)').matches;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dock = document.getElementById('nav-dock');
    if (!dock || !finePointer || reduced) return;

    const items = Array.from(dock.querySelectorAll<HTMLElement>('.dock-item'));
    const setters = items.map((el) => gsap.quickTo(el, 'scale', { duration: 0.32, ease: 'power3.out' }));

    const MAX = 1.34; // peak scale at the cursor
    const RANGE = 110; // px of influence on each side

    let centers: number[] = [];
    const cache = () => {
      centers = items.map((el) => {
        const r = el.getBoundingClientRect();
        return r.left + r.width / 2;
      });
    };

    const onMove = (e: PointerEvent) => {
      if (!centers.length) cache();
      for (let i = 0; i < items.length; i++) {
        const dist = Math.abs(e.clientX - centers[i]);
        const t = Math.max(0, 1 - dist / RANGE);
        setters[i](1 + (MAX - 1) * t * t);
      }
    };
    const onLeave = () => setters.forEach((s) => s(1));

    dock.addEventListener('pointerenter', cache);
    dock.addEventListener('pointermove', onMove);
    dock.addEventListener('pointerleave', onLeave);
    window.addEventListener('resize', cache);

    cleanupDock = () => {
      dock.removeEventListener('pointerenter', cache);
      dock.removeEventListener('pointermove', onMove);
      dock.removeEventListener('pointerleave', onLeave);
      window.removeEventListener('resize', cache);
    };
  }

  initDock();

  // Note: the `scrolled` class on #main-nav is driven by ScrollTrigger in
  // scripts/animations.ts (it owns the Lenis-synced scroll state).

  // Delegated handlers survive View Transition DOM swaps.
  // Capture phase + stopPropagation so this runs BEFORE Astro's ClientRouter
  // link interception — otherwise the router jumps to the anchor instantly
  // and Lenis never gets to animate the scroll.
  document.addEventListener(
    'click',
    (e) => {
      const el = e.target as HTMLElement;

      if (el.closest('.lang-toggle')) {
        e.preventDefault();
        toggleLang();
        return;
      }
      if (el.closest('.theme-toggle')) {
        e.preventDefault();
        toggleTheme();
        return;
      }

      const link = el.closest('[data-nav-link]') as HTMLAnchorElement | null;
      if (!link) return;

      const href = link.getAttribute('href') ?? '';
      const hashOnly = href.includes('#');

      // In-page anchor on the current page → Lenis smooth scroll, no navigation.
      if (isHome() && hashOnly) {
        const did = smoothScrollTo(href);
        if (did) {
          e.preventDefault();
          e.stopPropagation();
          const newHash = href.replace(/^.*(?=#)/, '') || '/';
          history.replaceState(null, '', newHash);
        }
      }
    },
    true // capture
  );

  // When landing on the home page with a hash (e.g. navigating back from a
  // project page via "/#projects"), smooth-scroll to it once Lenis is ready.
  document.addEventListener('astro:page-load', () => {
    // The page content is swapped on navigation — re-translate + re-theme it.
    syncPreferences();
    initDock();

    if (isHome() && window.location.hash) {
      const hash = window.location.hash;
      requestAnimationFrame(() => requestAnimationFrame(() => smoothScrollTo(hash)));
    }
  });
</script>
