---
import { profile } from '../data/profile';
import { es } from '../i18n/es';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-credit">
      © {year} {profile.name} · <span data-es={es.ui.footer.builtWith}>Built with</span> <span class="heart">♥</span> <span data-es={es.ui.footer.and}>and Astro</span>
    </p>
    <a href="/#top" class="footer-top" data-nav-link data-es={es.ui.footer.backToTop}>Back to top ↑</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .footer-credit,
  .footer-top {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .heart {
    color: var(--color-accent);
  }
  .footer-top {
    transition: color 200ms ease;
  }
  .footer-top:hover {
    color: var(--color-accent);
  }
</style>
